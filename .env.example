# =============================================================================
#  Alta Magia Daniel — environment example
#  Copy to .env / .env.local and fill with your Supabase Self-Hosted (Neura)
#  values. NEVER commit real secrets. .env* is git-ignored.
# =============================================================================

# ── Public (safe in the browser / admin client) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# This project uses an ISOLATED Postgres schema. The Supabase client must target
# it explicitly (do NOT rely on the implicit search_path from the frontend):
#   supabase.schema('altamagiadaniel').from('services')...
NEXT_PUBLIC_SUPABASE_SCHEMA=altamagiadaniel

# ── Server-only. NEVER expose in any client bundle or browser code ───────────
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string used ONLY to run migrations & seed with psql.
SUPABASE_DB_URL=

# ── Storage ──────────────────────────────────────────────────────────────────
SUPABASE_STORAGE_BUCKET=altamagiadaniel-media
